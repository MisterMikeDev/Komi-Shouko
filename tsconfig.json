{
    "compilerOptions": {
        "target": "es2016",
        "module": "commonjs",
        "allowJs": false,
        "outDir": "./Komipiled",
        "removeComments": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "noImplicitAny": false,
        "skipLibCheck": true,
        "resolveJsonModule": true
    },
    "exclude": [
        "node_modules",
        "package.json",
        "package-lock.json",
        "nodemon.json",
        "fly.toml",
        ".dockerignore"
    ]
}
