{
    "name": "komi-shouko",
    "version": "0.0.1",
    "main": "src/index.ts",
    "scripts": {
        "start": "tsc && node Komipiled/index.js",
        "dev": "nodemon --exec node --loader ts-node/esm/transpile-only src/index.ts",
        "api": "nodemon --exec node --loader ts-node/esm/transpile-only src/Api/index.ts",
        "build": "tsc",
        "format": "prettier . --write",
        "lint": "eslint .",
        "fix": "eslint . --fix",
        "test": "jest"
    },
    "author": "MrMikeDev",
    "license": "MIT",
    "repository": "https://github.com/MisterMikeDev/Komi-Shouko",
    "keywords": [
        "Discord",
        "Bot",
        "Komi",
        "Komi-Shouko",
        "Dev",
        "TypeScript"
    ],
    "dependencies": {
        "@discordjs/opus": "0.9.0",
        "@discordjs/voice": "0.13.0",
        "@iamtraction/google-translate": "2.0.0",
        "apollo-server-express": "^3.11.1",
        "bcryptjs": "2.4.3",
        "beautify": "0.0.8",
        "cors": "2.8.5",
        "discord-arts": "0.0.8",
        "discord.js": "^14.6.0",
        "dotenv": "16.0.3",
        "express": "4.18.2",
        "fs": "0.0.1-security",
        "glob": "8.0.3",
        "graphql": "16.6.0",
        "http": "0.0.1-security",
        "mongoose": "6.7.0",
        "path": "0.12.7",
        "pg": "8.8.0",
        "socket.io": "4.5.3",
        "util": "0.12.5"
    },
    "devDependencies": {
        "@babel/preset-env": "7.20.2",
        "@babel/preset-typescript": "7.18.6",
        "@jest/globals": "29.3.1",
        "@types/bcryptjs": "2.4.2",
        "@types/cors": "2.8.12",
        "@types/eslint": "8.4.10",
        "@types/express": "4.17.14",
        "@types/express-graphql": "0.9.0",
        "@types/glob": "8.0.0",
        "@types/graphql": "14.5.0",
        "@types/jest": "29.2.2",
        "@types/node": "18.11.8",
        "@types/pg": "8.6.5",
        "@types/socket.io": "3.0.2",
        "@typescript-eslint/eslint-plugin": "5.42.0",
        "@typescript-eslint/parser": "5.42.0",
        "chalk": "4.1.2",
        "eslint": "8.26.0",
        "eslint-config-prettier": "8.5.0",
        "jest": "29.3.1",
        "nodemon": "2.0.20",
        "prettier": "2.7.1",
        "ts-jest": "29.0.3",
        "ts-node": "10.9.1",
        "typescript": "4.8.4"
